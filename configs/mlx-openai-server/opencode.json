{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:8000/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "JANGQ-AI/Qwen3.5-35B-A3B-JANG_4K": {
          "name": "Qwen3.5-35B-A3B JANG 4-bit (Mixed Precision)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "mlx-community/Qwen3-Coder-30B-A3B-Instruct-4bit": {
          "name": "Qwen3-Coder-30B-A3B Instruct 4-bit",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "macstudio/JANGQ-AI/Qwen3.5-35B-A3B-JANG_4K",
  "small_model": "macstudio/mlx-community/Qwen3-Coder-30B-A3B-Instruct-4bit"
}
