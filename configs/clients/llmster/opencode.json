{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:1234/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "gemma-4-31b-it-mlx": {
          "name": "Gemma 4 31B-it 6bit (llmster, standard MLX) — dense agent-loop speed leader (browse 5.11 s, search 6.37 s)",
          "tools": true,
          "reasoning": false,
          "limit": {
            "context": 65536,
            "output": 4096
          }
        },
        "qwen3.6-27b": {
          "name": "Qwen3.6-27B 6bit (llmster, standard MLX) — dense + ViT, Qwen3 instruction-tuned",
          "tools": true,
          "reasoning": false,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "macstudio/gemma-4-31b-it-mlx",
  "small_model": "macstudio/gemma-4-31b-it-mlx"
}
