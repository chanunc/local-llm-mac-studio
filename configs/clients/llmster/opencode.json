{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:1234/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen3.6-27b-uncensored-balanced-q8kp": {
          "name": "Qwen3.6-27B Uncensored Balanced Q8_K_P (llmster, GGUF)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 65536,
            "output": 4096
          }
        },
        "qwen3.6-27b": {
          "name": "Qwen3.6-27B 6bit (llmster, standard MLX)",
          "tools": true,
          "reasoning": false,
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "gemma-4-31b-it-mlx": {
          "name": "Gemma 4 31B-it 6bit (llmster, standard MLX)",
          "tools": true,
          "reasoning": false,
          "limit": {
            "context": 65536,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "macstudio/qwen3.6-27b-uncensored-balanced-q8kp",
  "small_model": "macstudio/qwen3.6-27b-uncensored-balanced-q8kp"
}
