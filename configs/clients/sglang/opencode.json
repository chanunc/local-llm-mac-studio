{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio-sglang": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:30000/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "openbmb/MiniCPM5-1B": {
          "name": "OpenBMB MiniCPM5-1B via SGLang MLX (minicpm5 tool parser; No Think recommended)",
