{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio-llama-cpp-turboquant": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:8099/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "qwen3.6-35b-a3b-rotorquant-iso3": {
          "name": "Qwen3.6-35B-A3B Q6_K + RotorQuant iso3 KV cache (johndpope fork, provisional)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b-turboquant-turbo3": {
          "name": "Qwen3.6-35B-A3B Q6_K + TurboQuant turbo3 V (TheTom fork, agent-loop speed leader 2026-05-06)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "gemma4-12b-agentic-v2-q8-turbo3-256k": {
          "name": "Gemma 4 12B Agentic v2 Q8_0 + TurboQuant turbo3 KV (TheTom fork, 256K context)",
          "tools": true,
          "reasoning": true,
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "macstudio-llama-cpp-turboquant/gemma4-12b-agentic-v2-q8-turbo3-256k",
  "small_model": "macstudio-llama-cpp-turboquant/gemma4-12b-agentic-v2-q8-turbo3-256k"
}
