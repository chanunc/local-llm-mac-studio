{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:8000/v1",
        "apiKey": "<YOUR_API_KEY>",
        "timeout": 600000,
        "compatibility": "strict"
      },
      "models": {
        "mlx-community/Qwen3-Coder-Next-8bit": {
          "name": "Qwen3-Coder-Next 8-bit (Maximum Precision)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "nightmedia/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-qx64-hi-mlx": {
          "name": "Qwen3.5-27B Claude Opus Distilled (Reasoning)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "mlx-community/Qwen3.5-122B-A10B-4bit": {
          "name": "Qwen3.5-122B-A10B 4-bit (Agentic Reasoning)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "NexVeridian/OmniCoder-9B-8bit": {
          "name": "OmniCoder 9B 8-bit (Coding Agent)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "mlx-community/Qwen3.5-35B-A3B-8bit": {
          "name": "Qwen3.5 35B-A3B 8-bit (SWE Agent)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "nightmedia/Qwen3.5-35B-A3B-Holodeck-qx86-hi-mlx": {
          "name": "Qwen3.5-35B-A3B Holodeck (Hybrid Precision)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "NVIDIA-Nemotron-3-Nano-30B-A3B-MLX-8Bit": {
          "name": "Nemotron 3 Nano 30B-A3B 8-bit",
          "limit": {
            "context": 650000,
            "output": 8192
          }
        },
        "Huihui-Qwen3.5-35B-A3B-abliterated-8bit-mlx": {
          "name": "Huihui Qwen3.5-35B-A3B Abliterated 8-bit",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "macstudio/mlx-community/Qwen3.5-35B-A3B-8bit",
  "small_model": "macstudio/mlx-community/Qwen3.5-35B-A3B-8bit"
}
