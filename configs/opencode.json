{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "macstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://<MAC_STUDIO_IP>:8000/v1",
        "apiKey": "<YOUR_API_KEY>"
      },
      "models": {
        "mlx-community/Qwen3-Coder-Next-6bit": {
          "name": "Qwen3-Coder-Next 6-bit (Daily Driver)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "nightmedia/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-qx64-hi-mlx": {
          "name": "Qwen3.5-27B Claude Opus Distilled (Reasoning)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "mlx-community/Qwen3.5-122B-A10B-4bit": {
          "name": "Qwen3.5-122B-A10B 4-bit (Agentic Reasoning)",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "JANGQ-AI/Qwen3.5-122B-A10B-JANG_2S": {
          "name": "Qwen3.5-122B-A10B JANG 2S (Compact 122B)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "NexVeridian/OmniCoder-9B-8bit": {
          "name": "OmniCoder 9B 8-bit (Coding Agent)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "NVIDIA-Nemotron-3-Nano-30B-A3B-MLX-8Bit": {
          "name": "Nemotron 3 Nano 30B-A3B 8-bit",
          "limit": {
            "context": 650000,
            "output": 8192
          }
        },
        "inferencerlabs/NVIDIA-Nemotron-3-Super-120B-A12B-MLX-4.5bit": {
          "name": "Nemotron 3 Super 120B-A12B 4.5-bit (MoE)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "JANGQ-AI/Qwen3.5-35B-A3B-JANG_4K": {
          "name": "Qwen3.5-35B-A3B JANG 4-bit (Mixed Precision)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "RepublicOfKorokke/Nemotron-Cascade-2-30B-A3B-mlx-nvfp4": {
          "name": "Nemotron Cascade 2 30B-A3B nvfp4 (Mamba-2 Hybrid)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "macstudio/mlx-community/Qwen3-Coder-Next-6bit",
  "small_model": "macstudio/mlx-community/Qwen3-Coder-Next-6bit"
}
