{
  "$schema": "https://opencode.ai/config.schema.json",
  "providers": {
    "litert-lm": {
      "name": "LiteRT-LM",
      "type": "openai",
      "baseURL": "http://<MAC_STUDIO_IP>:9379/v1",
      "models": {
        "gemma4-e4b": {
          "name": "Gemma 4 E4B (LiteRT-LM)",
          "contextWindow": 3072,
          "maxOutputTokens": 1024
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "litert-lm/gemma4-e4b"
    }
  }
}
