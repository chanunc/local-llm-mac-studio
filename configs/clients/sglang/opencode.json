          "reasoning": false,
          "limit": {
            "context": 131072,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "macstudio-sglang/openbmb/MiniCPM5-1B",
  "small_model": "macstudio-sglang/openbmb/MiniCPM5-1B"
}
